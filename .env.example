# Copy to .env and fill in. NEVER commit the real .env.

# Password for the /admin booking dashboard (your friend uses this to log in).
ADMIN_PASSWORD=change-me

# Owner phone in international format for WhatsApp links (no + or spaces).
PUBLIC_WHATSAPP=12146560656

# --- Optional email notifications (gancho pronto, plugar depois) ---
# If set, every new booking is emailed to the owner. Uses Resend.
# Leave blank to disable email (WhatsApp + admin panel still work).
RESEND_API_KEY=
BOOKING_NOTIFY_EMAIL=
BOOKING_FROM_EMAIL=
