---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import Faq from '../../components/Faq.astro';
import BeforeAfter from '../../components/BeforeAfter.astro';
import Booking from '../../components/Booking.astro';
import { servicePages, site, areaLabel } from '../../lib/site';

export const prerender = true;

export function getStaticPaths() {
  return servicePages.map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
---
<Layout title={service.title} description={service.description} path={`/services/${service.slug}`}>
  <!-- Hero -->
  <section class="relative isolate flex min-h-[70svh] items-center overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-bg">
      <img src={service.image} alt={`${service.name} by Sena Premium Detailing in DFW`} class="absolute inset-0 h-full w-full object-cover" width="1600" height="1067" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-bg/45"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-bg via-bg/70 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg/30"></div>
    </div>
    <div class="mx-auto w-full max-w-7xl px-6 pt-28 pb-16 md:px-10">
      <div class="max-w-2xl">
        <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.22em] text-gold">
          <Icon name="mapPin" size={16} /> {service.eyebrow} · DFW, {site.region}
        </p>
        <h1 class="mt-5 font-display text-[clamp(2.25rem,5.5vw,4.25rem)] font-bold leading-[1.05]">
          {service.h1Lead} <span class="text-gold-gradient">{service.h1Accent}</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">{service.intro}</p>
        <div class="mt-7 inline-flex items-center gap-3 rounded-full border border-[var(--color-gold)]/30 bg-surface/70 px-5 py-2.5 backdrop-blur-sm">
          <Icon name="sparkles" size={18} class="text-gold" />
          <span class="text-sm md:text-base"><span class="text-muted">Starting </span><span class="font-display text-xl font-bold text-gold-gradient">{service.price}</span></span>
        </div>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="#booking" class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-gradient px-7 py-4 text-base font-semibold text-bg transition-transform hover:brightness-110">
            <Icon name="calendar" size={20} /> Get a Free Quote
          </a>
          <a href={`tel:${site.phoneHref}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 px-7 py-4 text-base font-semibold text-ink transition-colors hover:border-gold hover:text-gold">
            <Icon name="phone" size={20} /> {site.phoneDisplay}
          </a>
        </div>
        <p class="mt-8 text-sm text-muted">Serving {areaLabel}</p>
      </div>
    </div>
  </section>

  <!-- What's included + benefits -->
  <section class="border-y border-white/10 bg-surface py-20 md:py-28">
    <div class="mx-auto grid max-w-7xl gap-12 px-6 md:px-10 lg:grid-cols-2">
      <div class="reveal">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">What's Included</p>
        <h2 class="mt-4 font-display text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-tight">
          {service.name} <span class="text-gold-gradient">Done Right</span>
        </h2>
        <ul class="mt-7 space-y-3.5">
          {service.includes.map((f) => (
            <li class="flex items-start gap-3 text-base">
              <Icon name="check" size={20} class="mt-0.5 shrink-0 text-gold" />
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="reveal grid grid-cols-2 gap-4 self-start">
        {service.benefits.map((b) => (
          <div class="rounded-2xl border border-white/10 bg-surface-2 p-6">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-gold-gradient text-bg"><Icon name={b.icon} size={24} /></span>
            <p class="mt-4 text-sm font-medium">{b.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <BeforeAfter />

  <Faq items={service.faq} heading={`${service.name} — FAQ`} />

  <Booking />
</Layout>
