---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Quiz from '../components/Quiz.astro';
import TrustStrip from '../components/TrustStrip.astro';
import Services from '../components/Services.astro';
import Tint from '../components/Tint.astro';
import Process from '../components/Process.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Gallery from '../components/Gallery.astro';
import WhyUs from '../components/WhyUs.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Reviews from '../components/Reviews.astro';
import Faq from '../components/Faq.astro';
import Booking from '../components/Booking.astro';
import { homeFaq } from '../lib/site';

export const prerender = true;
---
<Layout
  title="Mobile Car Wash & Detailing in DFW, TX | Sena Premium"
  description="Premium mobile car wash & detailing across DFW — Frisco, Plano, McKinney & Dallas. We come to you. Detailing, window tint & ceramic coating from $99."
  path="/"
>
  <Hero />
  <TrustStrip />
  <Quiz />
  <Services />
  <Tint />
  <Process />
  <BeforeAfter />
  <Gallery />
  <WhyUs />
  <CtaBanner />
  <Reviews />
  <Faq items={homeFaq} />
  <Booking />
</Layout>
