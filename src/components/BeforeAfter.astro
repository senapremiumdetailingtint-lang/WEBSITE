---
import Icon from './Icon.astro';
import { beforeAfters, waDefault } from '../lib/site';

const first = beforeAfters[0];
const ar = (o: string) => (o === 'landscape' ? '4 / 3' : '3 / 4');
---
<section id="results" class="scroll-mt-24 py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">Real Results</p>
      <h2 class="mt-4 font-display text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-tight">
        Before & <span class="text-gold-gradient">After</span>
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Real cars, real clients. Drag the slider — and pick a transformation below.
      </p>
    </div>

    <!-- Slider -->
    <div class="reveal mt-12 flex justify-center">
      <div
        id="baWidget"
        class="ba relative h-[clamp(380px,62vh,580px)] touch-none select-none overflow-hidden rounded-2xl border border-white/10"
        style={`aspect-ratio:${ar(first.orientation)}`}
      >
        <img id="baAfter" src={first.after} alt="After a Sena detail" class="absolute inset-0 h-full w-full object-cover" decoding="async" />
        <img id="baBefore" src={first.before} alt="Before — vehicle as it arrived" class="absolute inset-0 h-full w-full object-cover" style="clip-path:inset(0 50% 0 0)" decoding="async" />

        <span class="pointer-events-none absolute left-3 top-3 rounded-full bg-bg/70 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-ink backdrop-blur-sm">Before</span>
        <span class="pointer-events-none absolute right-3 top-3 rounded-full bg-gold-gradient px-3 py-1 text-xs font-semibold uppercase tracking-wider text-bg">After</span>

        <div id="baHandle" class="pointer-events-none absolute inset-y-0 z-10 w-0.5 -translate-x-1/2 bg-gold" style="left:50%">
          <span class="absolute top-1/2 left-1/2 grid h-11 w-11 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-gold-gradient text-bg shadow-lg">
            <Icon name="arrowRight" size={18} class="-mr-1" />
            <Icon name="arrowRight" size={18} class="-ml-1 rotate-180" />
          </span>
        </div>

        <input id="baRange" type="range" min="0" max="100" value="50" step="0.1"
          aria-label="Reveal before and after"
          class="absolute inset-0 z-20 h-full w-full cursor-ew-resize opacity-0" />
      </div>
    </div>

    <!-- Transformation selector -->
    <div class="reveal mt-6 flex flex-wrap justify-center gap-3">
      {beforeAfters.map((b, i) => (
        <button
          type="button"
          class={`ba-thumb group flex items-center gap-2.5 rounded-full border py-1.5 pl-1.5 pr-4 transition-colors duration-200 ${i === 0 ? 'border-[var(--color-gold)] bg-surface-2' : 'border-white/15 hover:border-[var(--color-gold)]/50'}`}
          data-before={b.before}
          data-after={b.after}
          data-ar={ar(b.orientation)}
        >
          <img src={b.after} alt="" class="h-9 w-9 rounded-full object-cover" loading="lazy" decoding="async" />
          <span class="text-sm font-medium text-ink">{b.label}</span>
        </button>
      ))}
    </div>

    <div class="reveal mt-8 text-center">
      <a href={waDefault} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-gold-gradient px-7 py-4 text-base font-semibold text-bg transition-transform hover:brightness-110">
        <Icon name="sparkles" size={20} /> Get Results Like This
      </a>
    </div>
  </div>
</section>

<script>
  const widget = document.getElementById('baWidget');
  const range = document.getElementById('baRange') as HTMLInputElement | null;
  const before = document.getElementById('baBefore') as HTMLImageElement | null;
  const after = document.getElementById('baAfter') as HTMLImageElement | null;
  const handle = document.getElementById('baHandle');
  const thumbs = Array.from(document.querySelectorAll('.ba-thumb')) as HTMLElement[];

  function setPos(v: number) {
    const pos = Math.max(0, Math.min(100, v));
    if (before) before.style.clipPath = `inset(0 ${100 - pos}% 0 0)`;
    if (handle) handle.style.left = pos + '%';
  }

  range?.addEventListener('input', () => setPos(parseFloat(range.value)));

  thumbs.forEach((t) => {
    t.addEventListener('click', () => {
      if (before) before.src = t.dataset.before || '';
      if (after) after.src = t.dataset.after || '';
      if (widget && t.dataset.ar) widget.style.aspectRatio = t.dataset.ar;
      if (range) range.value = '50';
      setPos(50);
      thumbs.forEach((o) => {
        o.classList.remove('border-[var(--color-gold)]', 'bg-surface-2');
        o.classList.add('border-white/15');
      });
      t.classList.remove('border-white/15');
      t.classList.add('border-[var(--color-gold)]', 'bg-surface-2');
    });
  });
</script>
