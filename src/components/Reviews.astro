---
import Icon from './Icon.astro';
import { reviews, reviewStats } from '../lib/site';

const googleReviewsUrl =
  'https://www.google.com/search?q=Sena+Premium+Detailing+%26+Tint+reviews';
---
<section id="reviews" class="scroll-mt-24 border-t border-white/10 bg-surface py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <div class="reveal flex flex-col items-center text-center">
      <div class="flex gap-1 text-gold">
        {Array.from({ length: 5 }).map(() => <Icon name="star" size={22} />)}
      </div>
      <h2 class="mt-5 font-display text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-tight">
        {reviewStats.rating} Stars Across <span class="text-gold-gradient">North Dallas</span>
      </h2>
      <p class="mt-3 text-muted">
        Rated {reviewStats.rating} from {reviewStats.count} reviews on
        <a href={googleReviewsUrl} target="_blank" rel="noopener" class="text-gold underline">Google</a>.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      {reviews.map((r) => (
        <figure class="reveal flex flex-col rounded-2xl border border-white/10 bg-surface-2 p-7">
          <div class="flex gap-1 text-gold">
            {Array.from({ length: r.rating }).map(() => <Icon name="star" size={16} />)}
          </div>
          <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-ink">“{r.text}”</blockquote>
          <figcaption class="mt-5 flex items-center gap-2 text-sm">
            <span class="font-semibold text-ink">{r.name}</span>
            <span class="text-muted">· via Google</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="reveal mt-10 text-center">
      <a href={googleReviewsUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-white/15 px-6 py-3.5 text-sm font-semibold text-ink transition-colors hover:border-gold hover:text-gold">
        <Icon name="star" size={16} class="text-gold" /> Read our reviews on Google
      </a>
    </div>
  </div>
</section>
