---
import Icon from './Icon.astro';

const items = [
  { icon: 'shield', label: 'Licensed & Insured' },
  { icon: 'award', label: '100% Satisfaction Guarantee' },
  { icon: 'car', label: 'Fully Mobile — We Come to You' },
  { icon: 'droplet', label: 'No Water or Power Hookup Needed' },
];
---
<section class="border-y border-white/10 bg-surface">
  <div class="mx-auto max-w-7xl px-6 py-6 md:px-10">
    <ul class="grid grid-cols-2 gap-x-6 gap-y-5 md:grid-cols-4">
      {items.map((i) => (
        <li class="flex items-center gap-3">
          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-[var(--color-gold)]/25 text-gold">
            <Icon name={i.icon} size={20} />
          </span>
          <span class="text-sm font-medium text-ink">{i.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
