---
import Icon from './Icon.astro';
import { site } from '../lib/site';
---
<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <img
      src="/images/paint.jpg"
      alt="Glossy ceramic-coated car paint with water beading"
      class="h-full w-full object-cover"
      width="1024"
      height="1024"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-bg/75"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg"></div>
  </div>

  <div class="mx-auto max-w-3xl px-6 py-24 text-center md:py-32">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">Book Today</p>
    <h2 class="mt-4 font-display text-[clamp(2rem,5vw,3.5rem)] font-bold leading-tight">
      Your Best Detail Is <span class="text-gold-gradient">One Tap Away</span>
    </h2>
    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
      <a href="/#booking" class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-gradient px-7 py-4 text-base font-semibold text-bg transition-transform hover:brightness-110">
        <Icon name="calendar" size={20} /> Book Your Detail
      </a>
      <a href={`tel:${site.phoneHref}`} class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-bg/40 px-7 py-4 text-base font-semibold text-ink backdrop-blur-sm transition-colors hover:border-gold hover:text-gold">
        <Icon name="phone" size={20} /> {site.phoneDisplay}
      </a>
    </div>
  </div>
</section>
