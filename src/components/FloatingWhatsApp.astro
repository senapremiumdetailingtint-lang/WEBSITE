---
import Icon from './Icon.astro';
import { waDefault } from '../lib/site';
---
<a
  href={waDefault}
  target="_blank"
  rel="noopener"
  class="fixed bottom-5 right-5 z-30 flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3.5 font-semibold text-white shadow-lg shadow-black/40 transition-transform duration-200 hover:brightness-110"
  aria-label="Chat with us on WhatsApp"
>
  <Icon name="whatsapp" size={24} />
  <span class="hidden sm:inline">WhatsApp Us</span>
</a>
