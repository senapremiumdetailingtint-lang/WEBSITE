---
import Icon from './Icon.astro';
import { tintTiers } from '../lib/site';

const benefits = [
  { icon: 'sun', label: 'Up to 98% IR heat rejection' },
  { icon: 'shield', label: 'Blocks 99% of harmful UV rays' },
  { icon: 'droplet', label: 'Protects interior from fading & cracking' },
  { icon: 'award', label: 'Lifetime warranty on film' },
];
---
<section id="tint" class="scroll-mt-24 border-y border-white/10 bg-surface py-20 md:py-28">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 md:px-10 lg:grid-cols-2">
    <div class="reveal order-2 lg:order-1">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">Window Tint</p>
      <h2 class="mt-4 font-display text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-tight">
        Beat the <span class="text-gold-gradient">Texas Heat</span>
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Cooler cabin, protected interior, sharp look. Installed at your home,
        Texas-law compliant.
      </p>

      <ul class="mt-7 grid gap-4 sm:grid-cols-2">
        {benefits.map((b) => (
          <li class="flex items-center gap-3">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-[var(--color-gold)]/25 text-gold">
              <Icon name={b.icon} size={20} />
            </span>
            <span class="text-sm">{b.label}</span>
          </li>
        ))}
      </ul>

      <div class="mt-8 flex flex-wrap gap-4">
        {tintTiers.map((t) => (
          <div class="rounded-xl border border-white/10 bg-surface-2 px-5 py-4">
            <p class="font-display text-lg font-semibold">{t.name}</p>
            <p class="font-display text-2xl font-bold text-gold-gradient">{t.price}</p>
          </div>
        ))}
      </div>

      <a href="/#booking" class="mt-8 inline-flex items-center gap-2 rounded-full bg-gold-gradient px-7 py-4 text-base font-semibold text-bg transition-transform hover:brightness-110">
        Get a Tint Quote <Icon name="arrowRight" size={18} />
      </a>
    </div>

    <div class="reveal order-1 overflow-hidden rounded-2xl border border-white/10 lg:order-2">
      <img
        src="/images/tint.jpg"
        alt="Luxury black SUV with freshly applied professional window tint"
        class="aspect-[4/3] w-full object-cover"
        width="1376"
        height="768"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>
