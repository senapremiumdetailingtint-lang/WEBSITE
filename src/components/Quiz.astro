---
import Icon from './Icon.astro';

// Recommendation targets — `option` matches a value in the booking form's
// service <select>, so picking a result pre-selects it.
const recs = {
  essential: {
    name: 'Essential Detail',
    price: '$99',
    desc: 'A fast, thorough refresh inside and out — perfect for a well-kept car.',
    option: 'Essential Detail — $99',
  },
  premium: {
    name: 'Premium Detail',
    price: '$150',
    desc: 'A deep interior clean with steam, leather care and UV protection.',
    option: 'Premium Detail — $150',
  },
  premiumPlus: {
    name: 'Premium Plus Detail',
    price: '$185',
    desc: 'Shampoo, stain treatment and a ceramic sealant for lasting protection.',
    option: 'Premium Plus Detail — $185',
  },
  premiumFull: {
    name: 'Premium Full Detail',
    price: '$220',
    desc: 'Our most complete detail — full extraction and clay bar decontamination.',
    option: 'Premium Full Detail — $220',
  },
  ceramic: {
    name: 'Ceramic Coating',
    price: 'from $499',
    desc: 'Years of paint protection against the Texas sun. Often paired with a detail.',
    option: 'Ceramic Coating',
    href: '/services/ceramic-coating',
  },
};

const questions = [
  {
    q: 'What are you driving?',
    options: [
      { label: 'Car / Sedan', icon: 'car' },
      { label: 'SUV or Truck', icon: 'car' },
      { label: 'Luxury / Exotic', icon: 'sparkles' },
    ],
  },
  {
    q: 'What needs the most attention?',
    options: [
      { label: 'Just a wash & refresh', icon: 'droplet', score: 0 },
      { label: 'The inside — dust, dirt, smells', icon: 'car', score: 1 },
      { label: 'Stains, spills & heavy buildup', icon: 'sparkles', score: 2 },
      { label: 'Long-term paint protection', icon: 'shield', protection: true },
    ],
  },
  {
    q: 'When was it last detailed?',
    options: [
      { label: 'Recently — just upkeep', icon: 'check', score: 0 },
      { label: 'A few months ago', icon: 'clock', score: 1 },
      { label: "It's been a long time / never", icon: 'clock', score: 2 },
    ],
  },
];
---
<section id="quiz" class="scroll-mt-24 border-y border-white/10 bg-surface py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-6 md:px-10">
    <div class="reveal text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">Free Instant Quote</p>
      <h2 class="mt-4 font-display text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-tight">
        Find Your <span class="text-gold-gradient">Perfect Detail</span>
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Answer 3 quick questions and we'll recommend the right package — in 30 seconds.
      </p>
    </div>

    <div id="quizCard" class="reveal mt-10 rounded-2xl border border-white/10 bg-surface-2 p-6 md:p-10">
      <!-- Progress -->
      <div id="quizProgress" class="mb-7 flex items-center justify-between">
        <span class="text-xs font-semibold uppercase tracking-widest text-gold">Step <span id="quizStep">1</span> of 3</span>
        <div class="ml-4 h-1.5 flex-1 overflow-hidden rounded-full bg-white/10">
          <div id="quizBar" class="h-full bg-gold-gradient transition-[width] duration-300" style="width:33%"></div>
        </div>
      </div>

      <!-- Steps -->
      {questions.map((q, qi) => (
        <div class="quiz-step" data-step={qi} style={qi === 0 ? '' : 'display:none'}>
          <h3 class="font-display text-xl font-semibold md:text-2xl">{q.q}</h3>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            {q.options.map((o) => (
              <button
                type="button"
                class="quiz-opt group flex items-center gap-3 rounded-xl border border-white/12 bg-surface p-4 text-left transition-colors duration-200 hover:border-gold"
                data-score={('score' in o ? o.score : 0)}
                data-protection={('protection' in o && o.protection) ? '1' : '0'}
              >
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg border border-[var(--color-gold)]/30 text-gold transition-colors group-hover:bg-gold-gradient group-hover:text-bg">
                  <Icon name={o.icon} size={20} />
                </span>
                <span class="text-sm font-medium">{o.label}</span>
              </button>
            ))}
          </div>
        </div>
      ))}

      <!-- Result -->
      <div id="quizResult" style="display:none">
        <p class="text-xs font-semibold uppercase tracking-widest text-gold">We recommend</p>
        <h3 id="quizRecName" class="mt-2 font-display text-2xl font-bold md:text-3xl"></h3>
        <div class="mt-1 flex items-baseline gap-2">
          <span class="text-sm text-muted">starting at</span>
          <span id="quizRecPrice" class="font-display text-3xl font-bold text-gold-gradient"></span>
        </div>
        <p id="quizRecDesc" class="mt-3 text-muted"></p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <button type="button" id="quizBook" class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-gradient px-7 py-4 text-base font-semibold text-bg transition-transform hover:brightness-110">
            <Icon name="calendar" size={20} /> Book This Detail
          </button>
          <a id="quizLearn" href="#" class="hidden items-center justify-center gap-2 rounded-full border border-white/15 px-7 py-4 text-base font-semibold text-ink transition-colors hover:border-gold hover:text-gold">
            Learn more
          </a>
          <button type="button" id="quizRestart" class="inline-flex items-center justify-center gap-2 rounded-full px-5 py-4 text-sm font-medium text-muted transition-colors hover:text-ink">
            Start over
          </button>
        </div>
        <p class="mt-4 text-xs text-muted">No payment now — pay after your service. Final price depends on vehicle size & condition.</p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ recs }}>
  const steps = Array.from(document.querySelectorAll('.quiz-step'));
  const result = document.getElementById('quizResult');
  const bar = document.getElementById('quizBar');
  const stepNum = document.getElementById('quizStep');
  const progress = document.getElementById('quizProgress');
  let current = 0;
  let score = 0;
  let protection = false;

  function show(i) {
    steps.forEach((s, idx) => (s.style.display = idx === i ? '' : 'none'));
    if (stepNum) stepNum.textContent = String(i + 1);
    if (bar) bar.style.width = ((i + 1) / steps.length) * 100 + '%';
  }

  function finish() {
    let key = 'essential';
    if (protection) key = 'premiumPlus';
    else if (score >= 4) key = 'premiumFull';
    else if (score === 3) key = 'premiumPlus';
    else if (score === 2) key = 'premium';
    else key = 'essential';
    const rec = recs[key];

    document.getElementById('quizRecName').textContent = rec.name;
    document.getElementById('quizRecPrice').textContent = rec.price;
    document.getElementById('quizRecDesc').textContent = rec.desc;

    const learn = document.getElementById('quizLearn');
    const ceramicHint = protection ? recs.ceramic : null;
    if (ceramicHint) {
      learn.href = ceramicHint.href;
      learn.classList.remove('hidden');
      learn.classList.add('inline-flex');
      learn.textContent = 'Or explore Ceramic Coating';
    } else {
      learn.classList.add('hidden');
      learn.classList.remove('inline-flex');
    }

    steps.forEach((s) => (s.style.display = 'none'));
    if (progress) progress.style.display = 'none';
    result.style.display = 'block';

    document.getElementById('quizBook').onclick = () => {
      const sel = document.getElementById('service');
      if (sel) sel.value = rec.option;
      location.hash = '#booking';
    };
  }

  document.querySelectorAll('.quiz-opt').forEach((btn) => {
    btn.addEventListener('click', () => {
      score += Number(btn.dataset.score || 0);
      if (btn.dataset.protection === '1') protection = true;
      current++;
      if (current >= steps.length) finish();
      else show(current);
    });
  });

  document.getElementById('quizRestart')?.addEventListener('click', () => {
    current = 0; score = 0; protection = false;
    result.style.display = 'none';
    if (progress) progress.style.display = 'flex';
    show(0);
  });
</script>
