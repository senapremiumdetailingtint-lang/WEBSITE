---
import Icon from './Icon.astro';
import { site, areaLabel } from '../lib/site';
---
<section class="relative isolate flex min-h-[100svh] items-center overflow-hidden">
  <!-- Background image with dark fallback gradient -->
  <div class="absolute inset-0 -z-10 bg-bg">
    <!-- Fallback image: only shown until the video loads, on reduced-motion,
         or where video can't play. The video fully covers it otherwise. -->
    <img
      src="/images/hero.jpg"
      alt="Freshly detailed glossy black luxury car with water beading and golden light"
      class="absolute inset-0 h-full w-full object-cover"
      width="1600"
      height="894"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Background video: slow orbit of a luxury car being foamed -->
    <video
      class="absolute inset-0 h-full w-full object-cover motion-reduce:hidden"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster="/images/hero.jpg"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <!-- Darkening for legibility (over the media, not blended into it) -->
    <div class="absolute inset-0 bg-bg/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-bg via-bg/70 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg/30"></div>
  </div>

  <div class="mx-auto w-full max-w-7xl px-6 pt-28 pb-16 md:px-10">
    <div class="max-w-2xl">
      <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.22em] text-gold">
        <Icon name="mapPin" size={16} /> Mobile Car Wash & Detailing · DFW, {site.region}
      </p>

      <h1 class="mt-5 font-display text-[clamp(2.4rem,6vw,4.75rem)] font-bold leading-[1.05]">
        Mobile Car Wash &<br />Detailing That Makes<br />Your Car <span class="text-gold-gradient">Showroom New</span>
      </h1>

      <p class="mt-6 max-w-md text-lg leading-relaxed text-muted">
        Detailing & window tint, brought to your driveway. You don't lift a finger.
      </p>

      <!-- Offer pill -->
      <div class="mt-7 inline-flex items-center gap-2.5 rounded-full border border-[var(--color-gold)]/30 bg-surface/70 px-5 py-2.5 backdrop-blur-sm">
        <Icon name="sparkles" size={18} class="text-gold" />
        <span class="text-sm font-semibold md:text-base">Free Instant Quote</span>
      </div>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="#quiz" class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-gradient px-7 py-4 text-base font-semibold text-bg transition-transform duration-200 hover:brightness-110">
          <Icon name="sparkles" size={20} /> Find Your Detail
        </a>
        <a href="#booking" class="inline-flex items-center justify-center gap-2 rounded-full border border-white/15 px-7 py-4 text-base font-semibold text-ink transition-colors duration-200 hover:border-gold hover:text-gold">
          <Icon name="calendar" size={20} /> Book Now
        </a>
      </div>

      <p class="mt-8 text-sm text-muted">
        Serving {areaLabel}
      </p>
    </div>
  </div>
</section>
