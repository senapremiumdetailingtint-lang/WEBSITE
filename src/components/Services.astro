---
import Icon from './Icon.astro';
import { packages, comboOffer } from '../lib/site';
---
<section id="services" class="scroll-mt-24 py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <div class="reveal max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold">Detailing Packages</p>
      <h2 class="mt-4 font-display text-[clamp(2rem,4.5vw,3.25rem)] font-bold leading-tight">
        Choose Your Level of <span class="text-gold-gradient">Shine</span>
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Done at your home or office. From $89.
      </p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {packages.map((p) => (
        <div class={`reveal relative flex flex-col overflow-hidden rounded-2xl border transition-colors duration-300 ${p.featured ? 'border-[var(--color-gold)]/60 bg-surface-2' : 'border-white/10 bg-surface hover:border-[var(--color-gold)]/30'}`}>
          <div class="relative">
            <img
              src={p.image}
              alt={`${p.name} — Sena Premium Detailing`}
              class="aspect-[16/10] w-full object-cover"
              width="1024"
              height="640"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-surface)] to-transparent"></div>
            {p.featured && (
              <span class="absolute right-4 top-4 rounded-full bg-gold-gradient px-3 py-1 text-xs font-semibold text-bg">Most Popular</span>
            )}
            <div class="absolute bottom-3 left-5 right-5 flex items-end justify-between">
              <h3 class="font-display text-2xl font-semibold drop-shadow">{p.name}</h3>
              <span class="font-display text-3xl font-bold text-gold-gradient drop-shadow">{p.price}</span>
            </div>
          </div>

          <div class="flex flex-1 flex-col p-6">
            <p class="text-sm leading-relaxed text-muted">{p.blurb}</p>
            <ul class="mt-5 flex-1 space-y-2.5">
              {p.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm">
                  <Icon name="check" size={18} class="mt-0.5 shrink-0 text-gold" />
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <a href="/#booking" class={`mt-6 inline-flex items-center justify-center gap-2 rounded-full px-6 py-3.5 text-sm font-semibold transition-transform duration-200 hover:brightness-110 ${p.featured ? 'bg-gold-gradient text-bg' : 'border border-white/15 text-ink hover:border-gold hover:text-gold'}`}>
              Book Now <Icon name="arrowRight" size={16} />
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Combo offer -->
    <div class="reveal mt-8 flex flex-col items-center justify-between gap-5 rounded-2xl border border-[var(--color-gold)]/30 bg-[linear-gradient(120deg,rgba(216,189,116,0.08),transparent)] p-7 md:flex-row md:p-8">
      <div class="flex items-center gap-4">
        <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-gold-gradient text-bg">
          <Icon name="sparkles" size={24} />
        </span>
        <div>
          <h3 class="font-display text-xl font-semibold">{comboOffer.label} — <span class="text-gold-gradient">{comboOffer.discount}</span></h3>
          <p class="mt-1 text-sm text-muted">{comboOffer.blurb}</p>
        </div>
      </div>
      <a href="/#booking" class="shrink-0 rounded-full bg-gold-gradient px-6 py-3.5 text-sm font-semibold text-bg transition-transform hover:brightness-110">Get the Combo</a>
    </div>
  </div>
</section>
